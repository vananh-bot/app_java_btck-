<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>

<VBox alignment="CENTER" spacing="20.0" prefHeight="480.0" prefWidth="420.0"
      styleClass="otp-container" stylesheets="@../css/otp.css"
      xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="Controller.OtpController">

    <children>
        <Label text="Xác thực Email" styleClass="title-label" />

        <VBox alignment="CENTER" spacing="3.0">
            <Label text="Vui lòng nhập mã OTP gồm 6 chữ số đã được gửi" styleClass="info-label" />
            <HBox alignment="CENTER" spacing="5.0">
                <Label text="đến email:" styleClass="info-label" />
                <Label fx:id="emailDisplayLabel" text="dangcho..." styleClass="email-highlight" />
            </HBox>
        </VBox>

        <HBox alignment="CENTER" spacing="10.0" styleClass="otp-input-group">
            <TextField fx:id="otp1" prefHeight="55.0" prefWidth="45.0" styleClass="otp-field" />
            <TextField fx:id="otp2" prefHeight="55.0" prefWidth="45.0" styleClass="otp-field" />
            <TextField fx:id="otp3" prefHeight="55.0" prefWidth="45.0" styleClass="otp-field" />
            <TextField fx:id="otp4" prefHeight="55.0" prefWidth="45.0" styleClass="otp-field" />
            <TextField fx:id="otp5" prefHeight="55.0" prefWidth="45.0" styleClass="otp-field" />
            <TextField fx:id="otp6" prefHeight="55.0" prefWidth="45.0" styleClass="otp-field" />
        </HBox>

        <Label fx:id="errorLabel" text="Mã OTP không đúng!" visible="false" styleClass="error-label" />

        <Label fx:id="timerLabel" text="Mã OTP sẽ hết hạn trong 03:00 giây" styleClass="timer-label" />

        <Button fx:id="verifyButton" mnemonicParsing="false" onAction="#handleVerify"
                prefHeight="45.0" prefWidth="320.0" text="XÁC NHẬN" styleClass="verify-button" />

        <Hyperlink onAction="#handleResend" text="Gửi lại mã 🕒" styleClass="resend-link" />
    </children>

    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>
</VBox>