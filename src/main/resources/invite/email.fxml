        </Button>
        <VBox alignment="CENTER" layoutX="237.0" layoutY="92.0" maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" prefHeight="26.0" prefWidth="158.0" styleClass="card" stylesheets="@../css/email.css" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <StackPane prefHeight="19.0" prefWidth="54.0" styleClass="icon-container">
