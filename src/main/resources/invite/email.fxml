<AnchorPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" prefHeight="500.0" prefWidth="600.0" styleClass="root-pane" stylesheets="@../css/email.css" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.EmailInviteController">
    <children>
        <Button fx:id="close" mnemonicParsing="false" onAction="#handleCancel" style="-fx-background-color: transparent; -fx-cursor: hand;" textFill="#f4f0f0" AnchorPane.rightAnchor="7.0" AnchorPane.topAnchor="7.0">
            <graphic>
                <ImageView fitHeight="17.0" fitWidth="17.0" pickOnBounds="true" preserveRatio="true">
                    <image>
                        <Image url="@../images/close.png" />
