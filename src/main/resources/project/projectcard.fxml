<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressIndicator?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefWidth="470.0" stylesheets="@../css/allmyproject.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.ProjectCardController">
   <children>
      <VBox prefWidth="470.0" spacing="15.0" style="-fx-background-color: white; -fx-background-radius: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 15, 0, 0, 5);">
         <children>
            <HBox prefHeight="120.0" prefWidth="461.0">
               <children>
                  <Label fx:id="lblProjectName" alignment="TOP_LEFT" prefHeight="99.0" prefWidth="320.0" styleClass="project-title" wrapText="true">
                     <font>
                        <Font name="System Bold" size="22.0" />
                     </font>
                  </Label>
                  <ProgressIndicator fx:id="progressIndicator" maxHeight="100.0" maxWidth="100.0" prefHeight="100.0" prefWidth="100.0" progress="0.0" />
               </children>
               <padding>
                  <Insets left="15.0" />
               </padding>
            </HBox>
            <HBox alignment="CENTER_LEFT" prefHeight="38.0" prefWidth="461.0" spacing="2.0">
               <children>
                  <ImageView fitHeight="30.0" fitWidth="30.0" opacity="0.7" pickOnBounds="true" preserveRatio="true">
                     <image>
                        <Image url="@../images/hinhnguoi.png" />
                     </image>
                  </ImageView>
                  <Region HBox.hgrow="ALWAYS" />
                  <HBox spacing="5.0">
                     <children>
                        <HBox alignment="CENTER" spacing="5.0" styleClass="status-tag, todo">
                           <children>
                              <Label text="Todo" />
                              <Label fx:id="lblTodoCount" text="0" />
                           </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="5.0" styleClass="status-tag, in-progress">
                           <children>
                              <Label text="Doing" />
                              <Label fx:id="lblInProgressCount" text="0" />
                           </children>
                        </HBox>
                        <HBox alignment="CENTER" spacing="5.0" styleClass="status-tag, done">
                           <children>
                              <Label text="Done" />
                              <Label fx:id="lblDoneCount" text="0" />
                           </children>
                        </HBox>
                     </children>
                  </HBox>
               </children>
               <padding>
                  <Insets left="5.0" right="5.0" />
               </padding>
            </HBox>
         </children>
         <padding>
            <Insets bottom="15.0" left="25.0" right="25.0" top="25.0" />
         </padding>
      </VBox>
   </children>
</AnchorPane>