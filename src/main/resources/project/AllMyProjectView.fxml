<BorderPane maxHeight="1.7976931348623157E308" maxWidth="1.7976931348623157E308" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="1087.0" styleClass="white_pane" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="Controller.AllProjectController">
    <stylesheets>
        <URL value="@../css/global.css" />
        <URL value="@../css/taskdetails.css" />
        <URL value="@../css/allmyproject.css" />
    </stylesheets>
    <center>
      <StackPane BorderPane.alignment="CENTER">
         <children>
              <VBox prefHeight="200.0" prefWidth="100.0">
                  <children>
                      <HBox alignment="CENTER_LEFT" prefHeight="50.0" prefWidth="1053.0" styleClass="bottom_border">
                          <children>
                              <HBox prefHeight="30.0" prefWidth="556.0" styleClass="search-container">
                                  <HBox.margin>
                                      <Insets bottom="5.0" left="20.0" right="5.0" top="5.0" />
                                  </HBox.margin>
                                  <children>
                                      <Label alignment="CENTER" prefHeight="26.0" prefWidth="57.0" text="🔍" textAlignment="CENTER">
                                          <HBox.margin>
                                              <Insets left="15.0" />
                                          </HBox.margin>
                                      </Label>
                                      <TextField fx:id="searchInput" prefHeight="30.0" prefWidth="520.0" promptText="Tìm kiếm dự án" style="-fx-border-color: transparent;" styleClass="search-input" HBox.hgrow="ALWAYS">
