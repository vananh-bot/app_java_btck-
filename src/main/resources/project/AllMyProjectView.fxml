                                              </padding>
                                          </AnchorPane>
                                      </content>
                                  </ScrollPane>
                              <VBox fx:id="emptyProject" prefHeight="200.0" prefWidth="100.0" styleClass="vbox_card">
                                 <children>
                                    <ImageView fitHeight="318.0" fitWidth="386.0" pickOnBounds="true" preserveRatio="true">
                                       <image>
                                          <Image url="@../images/emptyProject-removebg-preview.png" />
                                       </image>
                                    </ImageView>
                                    <Label styleClass="setFontInVbox" text="Không có dự án nào">
                                       <font>
                                          <Font name="System Bold" size="12.0" />
                                       </font>
                                    </Label>
                                 </children>
                              </VBox>
                           </children>
