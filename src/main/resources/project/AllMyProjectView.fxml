                                              <Insets right="10.0" />
                                          </HBox.margin>
                              </TextField>
                                  </children>
                              </HBox>
                          </children>
                  </HBox>
                  <VBox prefHeight="650.0" prefWidth="1087.0" styleClass="grey_pane">
                     <children>
                            <HBox prefHeight="147.0" prefWidth="1087.0">
                                <children>
                                    <Label alignment="CENTER" prefHeight="70.0" prefWidth="269.0" text="Dự án của tôi" textAlignment="RIGHT">
                                        <font>
                                            <Font name="System Bold" size="35.0" />
                                        </font>
                                    </Label>
                                    <HBox prefHeight="100.0" prefWidth="674.0" />
                                    <VBox prefHeight="72.0" prefWidth="121.0">
                                        <children>
                                            <VBox prefHeight="34.0" prefWidth="131.0" />
