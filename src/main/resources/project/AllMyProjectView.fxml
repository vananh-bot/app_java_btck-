                                                <font>
                                                    <Font size="13.0" />
                                                </font>
                                            </Button>
                                        </children>
                                    </VBox>
                                </children>
                                <padding>
                                    <Insets bottom="15.0" left="25.0" right="20.0" top="15.0" />
                                </padding>
                            </HBox>
                        <StackPane VBox.vgrow="ALWAYS">
                           <children>
                                  <ScrollPane fitToWidth="true" hbarPolicy="NEVER" prefWidth="1086.0" style="-fx-background-color: transparent; -fx-background: transparent;">
                                      <content>
                                          <AnchorPane minHeight="0.0" minWidth="0.0" prefWidth="1072.0" style="-fx-background-color: transparent;">
                                              <children>
                                                  <FlowPane fx:id="projectContainer" hgap="25.0" layoutX="50.0" layoutY="9.0" prefWidth="1000.0" vgap="25.0">
                                                      <padding>
                                                          <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
                                                      </padding>
                                                  </FlowPane>
                                              </children>
                                              <padding>
